<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Barbearia Fernando Souza</title>

<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js"></script>

<style>
body { background:#0d0d0d; color:white; text-align:center; font-family:Arial; }
h1 { color:gold; }
.horarios { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; max-width:500px; margin:auto;}
.horario { padding:10px; border-radius:5px; cursor:pointer;}
.livre { background:green;}
.ocupado { background:red; cursor:not-allowed;}
input,select { width:90%; padding:10px; margin:5px; }
</style>
</head>

<body>

<h1>💈 Barbearia Fernando Souza</h1>

<input id="nome" placeholder="Seu nome">
<select id="servico">
<option>Corte</option>
<option>Barba</option>
<option>Sobrancelha</option>
<option>Depilação</option>
</select>

<h3>Escolha o horário</h3>
<div class="horarios" id="horarios"></div>

<script>
const firebaseConfig = {
  apiKey: "COLE_AQUI",
  authDomain: "COLE_AQUI",
  projectId: "COLE_AQUI",
};

firebase.initializeApp(firebaseConfig);
const db = firebase.firestore();

const horariosBase = ["07:30","08:00","08:30","09:00","09:30","10:00","10:30","11:00","11:30","12:00","13:00","14:00","15:00","16:00","17:00","18:00","19:00"];

async function render() {
  const container = document.getElementById("horarios");
  container.innerHTML = "";

  const snapshot = await db.collection("agenda").get();
  const ocupados = snapshot.docs.map(doc => doc.id);

  horariosBase.forEach(hora => {
    const div = document.createElement("div");
    div.innerText = hora;

    if (ocupados.includes(hora)) {
      div.className = "horario ocupado";
    } else {
      div.className = "horario livre";
      div.onclick = () => agendar(hora);
    }

    container.appendChild(div);
  });
}

async function agendar(hora) {
  const nome = document.getElementById("nome").value;
  const servico = document.getElementById("servico").value;

  if (!nome) return alert("Digite seu nome");

  await db.collection("agenda").doc(hora).set({
    nome,
    servico
  });

  window.open(`https://wa.me/5541999809818?text=Agendei ${servico} às ${hora}`);

  render();
}

render();
</script>

</body>
</html>
